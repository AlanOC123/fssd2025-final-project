# Frontend — lint and format staged TS/TSX files
cd frontend && pnpm lint-staged

# Backend — Ruff lint and Black format on staged Python files
cd ../backend && source .venv/bin/activate && ruff check . && black --check .

# Backend — run Django tests if any Python files are staged
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$')
if [ -n "$STAGED_PY" ]; then
    docker-compose -f ../docker-compose.yml run --rm web pytest
fi
