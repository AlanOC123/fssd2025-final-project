#!/bin/bash
# Usage: ./scripts/frontend/rebuild
# Hard rebuild of the client container only — use after adding packages.
# Stops client, removes the node_modules volume, builds with --no-cache,
# starts detached. db and web containers are left untouched.
#
# Note: ./scripts/frontend/add calls this automatically after installing,
# so you rarely need to run this directly.

set -e

cd "$(dirname "$0")/../.."

echo "1/3 Stopping client and clearing node_modules volume..."
docker-compose down client -v

echo "2/3 Rebuilding client from scratch..."
docker-compose build --no-cache client

echo "3/3 Starting frontend..."
docker-compose up -d client

echo "✅ Frontend rebuilt and running at http://localhost:5173"
