#!/bin/bash
# Usage: ./scripts/frontend/build
# Runs a production build (tsc + vite build) inside the client container.
# Output goes to frontend/dist/. Use before deploying or testing the build.

set -e

cd "$(dirname "$0")/../.."

echo "Building frontend for production..."
docker-compose run --rm client pnpm build

echo "✅ Production build complete. Output in frontend/dist/"
