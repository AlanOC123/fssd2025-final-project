#!/bin/bash
# Usage: ./scripts/frontend/compress-frontend

set -e

cd "$(dirname "$0")/../.."
echo "Attempting to compress frontend folder."

if [ ! -d "frontend" ]; then
    echo "Error: frontend directory not found"
    exit 1
fi

du -sh frontend

rm -f frontend.zip

zip -rq frontend.zip frontend \
    -x "*/node_modules/*" \
    "*/.git/*" \
    "*/.env*" \
    "*/.venv/*" \
    "*/.DS_Store" \
    "*/dist/*" \
    "*/.cache/*" \
    "*/.turbo/*" \
    "*/coverage/*" \
    "*/.nyc_output/*" \
    "*/.vite/*" \
    "*/storybook-static/*" \
    "*/*.log" \
    "*/\.pnpm-store/*"

echo "Frontend compressed to frontend.zip"
