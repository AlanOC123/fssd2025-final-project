#!/bin/bash
# Usage: ./scripts/core/nuke
# ⚠️  DESTRUCTIVE — wipes everything and starts from zero.
# Removes all containers, named + anonymous volumes (including pg_data),
# and the Docker builder cache. Use when the stack is in a broken state
# or you need a guaranteed clean slate.
#
# After running this you'll need to run:
#   ./scripts/db/reset    (to recreate and seed the database)
#   ./scripts/backend/start
#   ./scripts/frontend/dev

set -e

cd "$(dirname "$0")/../.."

echo "⚠️  Nuking Apex stack — all data will be lost."
echo ""
read -p "Are you sure? (y/N): " confirm
if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "Aborted."
    exit 0
fi

echo ""
echo "1/3 Stopping all containers and removing volumes..."
docker-compose down -v --remove-orphans

echo "2/3 Removing named volumes..."
docker volume rm apex_pg_data 2>/dev/null && echo "  Removed apex_pg_data" || echo "  apex_pg_data not found, skipping"
docker volume prune -f

echo "3/3 Clearing Docker builder cache..."
docker builder prune -a -f

echo ""
echo "✅ Stack fully wiped."
echo ""
echo "Next steps:"
echo "  Clear cookies and site data from brower application window. Chrome: Dev Tools -> Application -> Storage -> Clear Site Data (clean slate)"
echo "  ./scripts/db/reset      — recreate and seed the database"
echo "  ./scripts/backend/start — start the backend"
echo "  ./scripts/frontend/dev  — start the frontend"
