#!/bin/bash
# Usage: ./scripts/backend/rebuild
# Hard rebuild of the web container only — use when requirements.txt changes.
# Stops web, builds with --no-cache, restarts detached.
# db and client containers are left untouched.

set -e

cd "$(dirname "$0")/../.."

echo "1/3 Stopping web container..."
docker-compose stop web

echo "2/3 Rebuilding web from scratch..."
docker-compose build --no-cache web

echo "3/3 Starting backend..."
docker-compose up -d web

echo "✅ Backend rebuilt and running at http://localhost:8000"
