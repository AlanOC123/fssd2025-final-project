#!/bin/bash
# Usage: ./scripts/backend/manage <command> [args]
# Passthrough for any Django management command.
#
# Examples:
#   ./scripts/backend/manage showmigrations
#   ./scripts/backend/manage show_urls
#   ./scripts/backend/manage createsuperuser
#   ./scripts/backend/manage check

set -e

cd "$(dirname "$0")/../.."

docker-compose run --rm web python manage.py "$@"
